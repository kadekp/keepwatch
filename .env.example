# keepwatch — example .env
# Copy this file to .env and fill in real values. Never commit the real .env.
#
# These variables are consumed by go2rtc.yaml (${VAR} substitution) and by
# docker-compose. The detector itself reads detector.yaml, not this file.

# --- Camera RTSP URLs -------------------------------------------------------
# One variable per camera. Names here are just examples — feel free to rename
# them, but make sure go2rtc.yaml references the same names.
CAM_FRONT_RTSP=rtsp://user:password@192.0.2.10:554/stream1
CAM_BACK_RTSP=rtsp://user:password@192.0.2.11:554/stream1
# Some cameras expose a low-bitrate substream alongside the main feed; if
# you want to use it, give it its own variable:
# CAM_FRONT_RTSP_LOW=rtsp://user:password@192.0.2.10:554/stream2

# --- Dashboard HTTP basic auth ---------------------------------------------
# The go2rtc dashboard sits behind HTTP basic auth. Pick a username + a
# strong random password. Anyone hitting :1984 will be prompted.
GO2RTC_API_USER=admin
GO2RTC_API_PASSWORD=replace-me-with-a-strong-random-password

# --- Network bind addresses ------------------------------------------------
# By default keepwatch binds to 127.0.0.1, meaning only processes on the
# same host can reach the dashboard. Change this to expose it on your LAN
# or VPN (e.g. a Tailscale IP). NEVER set 0.0.0.0 unless you understand the
# security implications — see docs/security.md.
LISTEN_HOST=127.0.0.1
